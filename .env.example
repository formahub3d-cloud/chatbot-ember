# ── Selezione provider ──────────────────────────────────────────────
# LLM per il dialogo: "mistral" oppure "claude"
LLM_PROVIDER=mistral
# Embeddings: "mistral" (consigliato, UE). NB: Claude NON ha embeddings nativi.
EMBED_PROVIDER=mistral

# ── Chiavi API ──────────────────────────────────────────────────────
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# ── Modelli ─────────────────────────────────────────────────────────
MISTRAL_LLM_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
CLAUDE_LLM_MODEL=claude-haiku-4-5

# ── Qdrant (free tier va benissimo per iniziare) ────────────────────
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=cervello

# ── Cervello (vault Obsidian) ───────────────────────────────────────
VAULT_PATH=/Users/imac/Desktop/OVY-Cervello

# ── Sicurezza ───────────────────────────────────────────────────────
ADMIN_TOKEN=cambia-questo-token-admin
RATE_LIMIT_PER_MIN=30
MAX_MESSAGE_CHARS=2000
SECURITY_HEADERS=true
# CORS: "*" per il pilota, oppure lista di domini separati da virgola in produzione.
CORS_ORIGINS=*

# ── Voce PRO (opzionale) ────────────────────────────────────────────
# Vuoto = disabilitata: il widget usa la voce gratuita del browser (Web Speech API).
# Attiva impostando VOICE_PROVIDER e la relativa chiave (le chiavi restano sul server).
VOICE_PROVIDER=
VOICE_LANG=it
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Tenant store MongoDB (opzionale, consigliato in produzione) ─────
# Chiavi HASHATE (mai in chiaro), quote giornaliere, revoca. Precede Postgres/statico.
# Semina + gestione:  railway run python -m app.manage_tenants seed | add | list | revoke | rotate
MONGO_URI=
MONGO_DB=ember

# ── Backend grant Supabase (api_keys OVYON) — onboarding/CLI, GDPR ──
# GRANTS_BACKEND=supabase + DATABASE_URL attivano la tabella api_keys (a tre livelli,
# audit su access_logs) e le funzioni GDPR/onboarding (python -m app.manage_apikeys).
GRANTS_BACKEND=
DATABASE_URL=

# ── GDPR: cifratura a riposo + retention ────────────────────────────
# Cifratura del corpo nota (documents.content_encrypted). Vuoto = disattivata.
# Una o più chiavi Fernet separate da virgola (la prima cifra, tutte decifrano →
# rotazione). Genera una chiave con:  python -m app.crypto
CONTENT_ENC_KEY=
# Retention eventi analytics: cancella gli eventi più vecchi di N giorni quando si
# lancia POST /admin/retention/run (o /admin/retention/run?dry_run=true per l'anteprima).
# 0 = nessuna cancellazione. Persistenza eventi: ANALYTICS_PERSIST=true (richiede Supabase).
ANALYTICS_PERSIST=false
RETENTION_DAYS=0

# ── Billing Stripe (opzionale) — checkout a livelli + webhook ───────
# Inerte finché STRIPE_SECRET_KEY è vuota. I price-id si creano nel dashboard Stripe
# (Prodotti → Prezzi). Il webhook secret viene dal endpoint webhook Stripe. Mai commit.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
