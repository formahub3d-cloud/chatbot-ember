# ── Selezione provider ──────────────────────────────────────────────
# LLM per il dialogo: "mistral" oppure "claude"
LLM_PROVIDER=mistral
# Embeddings: "mistral" (consigliato, UE). NB: Claude NON ha embeddings nativi.
EMBED_PROVIDER=mistral

# ── Chiavi API ──────────────────────────────────────────────────────
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# ── Modelli ─────────────────────────────────────────────────────────
MISTRAL_LLM_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
CLAUDE_LLM_MODEL=claude-haiku-4-5

# ── Qdrant (free tier va benissimo per iniziare) ────────────────────
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=cervello

# ── Cervello (vault Obsidian) ───────────────────────────────────────
VAULT_PATH=/Users/imac/Desktop/OVY-Cervello
# Auto-ingest da git (opzionale): se valorizzato, prima di indicizzare il vault viene
# aggiornato dal repo (git pull se già clonato in VAULT_PATH, altrimenti git clone).
# Su Railway serve a rendere davvero fresco il cervello dopo un push del vault. Vuoto =
# comportamento storico (legge la cartella VAULT_PATH così com'è).
VAULT_GIT_URL=
# Token per repo PRIVATO (iniettato come x-access-token nell'URL, MAI loggato). È un
# SEGRETO: qui solo il segnaposto vuoto, il valore reale va nelle env di Railway, mai in git.
VAULT_GIT_TOKEN=
# Realtime: dopo un write-back confermato, re-indicizza SUBITO (incrementale) la nota
# appena scritta → il cervello la riflette man mano, senza attendere un ingest completo.
# OFF di default (opt-in). Best-effort: un errore non blocca mai il write-back.
AUTO_REINGEST=false

# ── Sicurezza ───────────────────────────────────────────────────────
ADMIN_TOKEN=cambia-questo-token-admin
RATE_LIMIT_PER_MIN=30
MAX_MESSAGE_CHARS=2000
SECURITY_HEADERS=true
# CORS: "*" per il pilota, oppure lista di domini separati da virgola in produzione.
CORS_ORIGINS=*

# ── Ricerca web (capability agente, OPT-IN) ─────────────────────────
# Divina può cercare su internet via Tavily oltre a rispondere dal cervello. OFF di
# default e INERTE finché TAVILY_API_KEY è vuota (nessuna chiamata, nessun costo).
# Gating: WEB_SEARCH=true (globale) oppure branding.web_search=true del singolo tenant.
# Con capability OFF /chat è identico a oggi. TAVILY_API_KEY è un SEGRETO: solo il
# segnaposto vuoto qui, il valore reale nelle env di Railway, mai in git.
TAVILY_API_KEY=
WEB_SEARCH=false

# ── Ponte agenti Divina (ovy-orchestrator) — capability OPT-IN ──────
# Quando la chat riceve un COMPITO (non semplice Q&A), Divina può instradarlo all'agente
# Divina giusto (Dante/Virgilio/Beatrice) via POST {DIVINA_URL}/agents/route, invece di
# rispondere col RAG. GATING (non negoziabile): opera SOLO con AGENTS_BRIDGE=true E
# DIVINA_URL + DIVINA_ADMIN_TOKEN valorizzati. Con OFF o senza config /chat è identico a
# oggi (RAG), nessuna chiamata a Divina. Trigger: flag agent:true nel body di /chat; con
# AGENTS_AUTO=true anche un euristico "task-like" (verbo imperativo) auto-instrada.
# A Divina passa SOLO il tenant_code (lo scope lo applica Divina con la sua RLS): il RAG
# non cambia. DIVINA_ADMIN_TOKEN è un SEGRETO: solo segnaposto qui, valore reale nelle
# env di deploy, mai in git.
AGENTS_BRIDGE=false
AGENTS_AUTO=false
DIVINA_URL=
DIVINA_ADMIN_TOKEN=

# ── Voce PRO (opzionale) ────────────────────────────────────────────
# Vuoto = disabilitata: il widget usa la voce gratuita del browser (Web Speech API).
# Attiva impostando VOICE_PROVIDER e la relativa chiave (le chiavi restano sul server).
VOICE_PROVIDER=
VOICE_LANG=it
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Tenant store MongoDB (opzionale, consigliato in produzione) ─────
# Chiavi HASHATE (mai in chiaro), quote giornaliere, revoca. Precede Postgres/statico.
# Semina + gestione:  railway run python -m app.manage_tenants seed | add | list | revoke | rotate
MONGO_URI=
MONGO_DB=ember

# ── Backend grant Supabase (api_keys OVYON) — onboarding/CLI, GDPR ──
# GRANTS_BACKEND=supabase + DATABASE_URL attivano la tabella api_keys (a tre livelli,
# audit su access_logs) e le funzioni GDPR/onboarding (python -m app.manage_apikeys).
GRANTS_BACKEND=
DATABASE_URL=

# ── GDPR: cifratura a riposo + retention ────────────────────────────
# Cifratura del corpo nota (documents.content_encrypted). Vuoto = disattivata.
# Una o più chiavi Fernet separate da virgola (la prima cifra, tutte decifrano →
# rotazione). Genera una chiave con:  python -m app.crypto
CONTENT_ENC_KEY=
# Retention eventi analytics: cancella gli eventi più vecchi di N giorni quando si
# lancia POST /admin/retention/run (o /admin/retention/run?dry_run=true per l'anteprima).
# 0 = nessuna cancellazione. Persistenza eventi: ANALYTICS_PERSIST=true (richiede Supabase).
ANALYTICS_PERSIST=false
RETENTION_DAYS=0

# ── Billing Stripe (opzionale) — checkout a livelli + webhook ───────
# Inerte finché STRIPE_SECRET_KEY è vuota. I price-id si creano nel dashboard Stripe
# (Prodotti → Prezzi). Il webhook secret viene dal endpoint webhook Stripe. Mai commit.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
# Setup fee una tantum al checkout — INERTE di default (false): il checkout resta
# identico a oggi. Con BILLING_SETUP_FEE=true il tier aggiunge, oltre al canone,
# un price ONE-TIME risolto per lookup_key (prezzi gia' creati su Stripe, uno per
# tier). I lookup_key NON sono segreti: sono etichette dei prezzi, ok in chiaro.
BILLING_SETUP_FEE=false
STRIPE_SETUP_LOOKUP_STARTER=setup_starter_dante
STRIPE_SETUP_LOOKUP_PRO=setup_business_virgilio
STRIPE_SETUP_LOOKUP_ENTERPRISE=setup_enterprise_beatrice
