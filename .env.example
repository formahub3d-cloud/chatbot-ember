# ── Selezione provider ──────────────────────────────────────────────
# LLM per il dialogo: "mistral" oppure "claude"
LLM_PROVIDER=mistral
# Embeddings: "mistral" (consigliato, UE). NB: Claude NON ha embeddings nativi.
EMBED_PROVIDER=mistral

# ── Chiavi API ──────────────────────────────────────────────────────
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# ── Modelli ─────────────────────────────────────────────────────────
MISTRAL_LLM_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
CLAUDE_LLM_MODEL=claude-haiku-4-5

# ── Qdrant (free tier va benissimo per iniziare) ────────────────────
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=cervello

# ── Cervello (vault Obsidian) ───────────────────────────────────────
VAULT_PATH=/Users/imac/Desktop/OVY-Cervello

# ── Sicurezza ───────────────────────────────────────────────────────
ADMIN_TOKEN=cambia-questo-token-admin
