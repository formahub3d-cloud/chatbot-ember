# OVY Brain Connector — configurazione
# Base URL di Divina (il chatbot integrato in OVYON)
EMBER_API_URL=http://localhost:8000
# Chiave-tenant: definisce lo scope (org/tenant/sotto-tenant) visibile al connettore.
# NON committare la chiave reale.
EMBER_TENANT_KEY=CHIAVE_TENANT
# Timeout richieste in secondi (opzionale)
EMBER_TIMEOUT=30
